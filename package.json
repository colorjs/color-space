{
  "name": "color-space",
  "description": "Any color space",
  "version": "3.0.0-next.0",
  "author": "Dmitry Ivanov <df.creative@gmail.com>",
  "type": "module",
  "keywords": [
    "color",
    "colour",
    "color-space",
    "color-conversion",
    "color-science",
    "rgb",
    "hsl",
    "hsv",
    "lab",
    "xyz",
    "oklab",
    "oklch",
    "lch",
    "cmyk",
    "yuv",
    "p3",
    "rec2020",
    "hdr",
    "wide-gamut",
    "css-color",
    "perceptual",
    "chromatic-adaptation",
    "cam16",
    "ciecam02",
    "munsell",
    "aces",
    "slog3",
    "cinema"
  ],
  "repository": "colorjs/color-space",
  "license": "CC0-1.0",
  "main": "./index.js",
  "types": "./types/index.d.ts",
  "files": [
    "*.js",
    "spaces",
    "data.json",
    "wasm",
    "gl",
    "types",
    "dist"
  ],
  "bin": {
    "color-space-mcp": "./mcp.js"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./index.js": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./lite": {
      "types": "./types/lite.d.ts",
      "default": "./lite.js"
    },
    "./lite.js": {
      "types": "./types/lite.d.ts",
      "default": "./lite.js"
    },
    "./lut": {
      "types": "./types/lut.d.ts",
      "default": "./lut.js"
    },
    "./lut.js": {
      "types": "./types/lut.d.ts",
      "default": "./lut.js"
    },
    "./icc": {
      "types": "./types/icc.d.ts",
      "default": "./icc.js"
    },
    "./icc.js": {
      "types": "./types/icc.d.ts",
      "default": "./icc.js"
    },
    "./data.json": "./data.json",
    "./wasm": {
      "types": "./types/wasm.d.ts",
      "default": "./wasm.js"
    },
    "./wasm.js": {
      "types": "./types/wasm.d.ts",
      "default": "./wasm.js"
    },
    "./color-space.wasm": "./dist/color-space.wasm",
    "./gl": {
      "types": "./types/gl.d.ts",
      "default": "./gl/compose.js"
    },
    "./gl/all": {
      "types": "./types/gl.d.ts",
      "default": "./gl/index.js"
    },
    "./gl/wgsl": "./gl/wgsl.js",
    "./gl/translate": "./gl/translate.js",
    "./gl/*.glsl.js": "./gl/*.glsl.js",
    "./gl/*.js": "./gl/*.js",
    "./gl/*": "./gl/*.glsl.js",
    "./hub.js": {
      "types": "./types/hub.d.ts",
      "default": "./hub.js"
    },
    "./mcp.js": "./mcp.js",
    "./gamuts.js": {
      "types": "./types/gamuts.d.ts",
      "default": "./gamuts.js"
    },
    "./whitepoints.js": {
      "types": "./types/whitepoints.d.ts",
      "default": "./whitepoints.js"
    },
    "./util.js": {
      "types": "./types/util.d.ts",
      "default": "./util.js"
    },
    "./transfers.js": "./transfers.js",
    "./cie.js": "./cie.js",
    "./spaces/*.js": {
      "types": "./types/*.d.ts",
      "default": "./spaces/*.js"
    },
    "./*.js": {
      "types": "./types/*.d.ts",
      "default": "./spaces/*.js"
    },
    "./*": {
      "types": "./types/*.d.ts",
      "default": "./spaces/*.js"
    }
  },
  "devDependencies": {
    "color-name": "^2.0.0",
    "esbuild": "^0.24.2",
    "jz": "^0.9.2",
    "tst": "^9.0.0"
  },
  "optionalDependencies": {
    "@texel/color": "^1.1.11",
    "chroma-js": "^3.1.2",
    "color-convert": "^2.0.1",
    "colorjs.io": "^0.5.2",
    "culori": "^4.0.1",
    "watr": "^3.1.0"
  },
  "scripts": {
    "test": "node test && node test/cie.js && node test/batch.js && node test/wasm-batch.js && node test/wasm-standalone.js && node test/gl.js && node test/visible.js && node test/lut.js && node test/lut-ffmpeg.js && node test/icc.js && node test/icc-colorsync.js && node test/mcp.js",
    "benchmark": "node benchmark/compare.js",
    "types": "node scripts/generate-types.js",
    "data": "node scripts/generate-data.js",
    "landing": "node scripts/build-site.js",
    "banner": "node scripts/generate-banner.js",
    "build:wasm": "node scripts/build-wasm.js",
    "build": "esbuild ./index.js --bundle --format=esm --outfile=dist/color-space.js && esbuild ./dist/color-space.js --minify --outfile=dist/color-space.min.js && esbuild ./lite.js --bundle --format=esm --outfile=dist/color-space-lite.js && esbuild ./gl/index.js --bundle --format=esm --outfile=dist/color-space-gl.js",
    "prepare": "npm run types && npm run data && npm run build:wasm && npm run build"
  }
}
