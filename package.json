{
  "name": "color-space",
  "description": "Every color space in one tiny API — 123 of them, CSS-style ranges, formulas verified vs colorjs.io, zero-dep & tree-shakeable",
  "version": "3.0.0",
  "author": "Dmitry Ivanov <df.creative@gmail.com>",
  "type": "module",
  "keywords": [
    "color",
    "colour",
    "color-space",
    "color-conversion",
    "color-science",
    "rgb",
    "hsl",
    "hsv",
    "lab",
    "xyz",
    "oklab",
    "oklch",
    "lch",
    "cmyk",
    "yuv",
    "p3",
    "rec2020",
    "hdr",
    "wide-gamut",
    "css-color",
    "perceptual",
    "chromatic-adaptation",
    "cam16",
    "ciecam02",
    "munsell",
    "aces",
    "slog3",
    "cinema"
  ],
  "repository": "colorjs/color-space",
  "license": "Unlicense",
  "main": "./index.js",
  "types": "./types/index.d.ts",
  "files": [
    "*.js",
    "types",
    "dist",
    "meta"
  ],
  "exports": {
    ".": "./index.js",
    "./*.js": "./*.js",
    "./*": "./*.js"
  },
  "devDependencies": {
    "color-name": "^2.0.0",
    "esbuild": "^0.24.2",
    "tst": "^9.0.0"
  },
  "optionalDependencies": {
    "chroma-js": "^3.1.2",
    "color-convert": "^2.0.1",
    "colorjs.io": "^0.5.2",
    "culori": "^4.0.1",
    "watr": "^3.1.0"
  },
  "scripts": {
    "test": "node test && node test/cie.js",
    "benchmark": "node benchmark/compare.js",
    "types": "node scripts/generate-types.js",
    "meta": "node scripts/generate-meta.js > meta.js",
    "build": "esbuild ./index.js --bundle --format=esm --outfile=dist/color-space.js && esbuild ./dist/color-space.js --minify --outfile=dist/color-space.min.js",
    "prepublishOnly": "npm run types && npm run meta && npm run build"
  }
}
